# --- OpenRouter (obbligatorio per riassunti e raggruppamento) ---
OPENROUTER_API_KEY=
# Modello gratuito su OpenRouter (cambiabile)
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# --- Email digest mattutino (OPZIONALE) ---
# Se lasci vuoto, il digest non viene spedito ma resta visibile in-app.
# Per Gmail serve una "App Password": https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DIGEST_TO=

# Ora del digest mattutino (24h)
DIGEST_HOUR=8
DIGEST_MINUTE=0

# Ogni quante ore fare lo scrape automatico
SCRAPE_EVERY_HOURS=2
