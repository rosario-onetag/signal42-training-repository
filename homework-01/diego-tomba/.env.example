# Prisma datasource. SQLite by default — swap the provider/URL in
# prisma/schema.prisma to move to Postgres/MySQL without touching the domain.
DATABASE_URL="file:./dev.db"

# CLI only — nella web app GitHub token e Anthropic API key si configurano
# dalla scheda "Setup" e vengono salvati nel database locale.
# GITHUB_TOKEN=ghp_xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
